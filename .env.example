# ============================================================================
# CONFIGURAÇÃO DO SUPABASE (OBRIGATÓRIO)
# ============================================================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anonima_do_supabase

# ============================================================================
# CONFIGURAÇÃO BRAVE SEARCH (OPCIONAL)
# ============================================================================
# Para usar busca mais precisa com Brave Search API
# Deixe em branco se não quiser usar
# Obtenha em: https://api.search.brave.com/
VITE_BRAVE_API_KEY=sua_chave_brave_aqui_opcional

# ============================================================================
# NOTAS
# ============================================================================
# - VITE_SUPABASE_URL e VITE_SUPABASE_ANON_KEY são OBRIGATÓRIOS
# - VITE_BRAVE_API_KEY é OPCIONAL (DuckDuckGo funciona sem ela)
# - Nunca commite este arquivo no Git
# - Use .env.local para desenvolvimento local
